# AI Provider Configuration
# Options: "mock" | "openai_compatible"
AI_PROVIDER=mock

# OpenAI-compatible API settings (only needed when AI_PROVIDER=openai_compatible)
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# Database
DATABASE_URL=sqlite:///./lifearchive.db

# Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
